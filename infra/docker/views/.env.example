# Internal port the Rust app listens on (inside the container).
# nginx-proxy-manager forwards traffic to this port via the `views` alias on the edge network.
VIEWS_PORT=3000

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# Comma-separated list of usernames allowed to be counted. Anyone else gets an
# "not allowed" error badge and never touches the counter table. Case-insensitive.
ALLOWED_USERNAMES=TraceofLight

# Salt used when hashing client IPs for the per-IP dedup window (1 hour).
# Replace with a random hex string. Only meaningful for privacy of stored hashes —
# consistency across restarts preserves the dedup window.
IP_HASH_SALT=replace-with-random-hex
